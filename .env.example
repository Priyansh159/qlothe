# Neon — use the POOLED connection string (has -pooler in host) for the app
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/qlothe?sslmode=require"
# Direct (non-pooled) URL — Prisma migrations need it
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/qlothe?sslmode=require"

RAZORPAY_KEY_ID="rzp_test_xxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxx"   # only the ID is public, never secrets
RAZORPAY_KEY_SECRET="xxxx"
RAZORPAY_WEBHOOK_SECRET="xxxx"                # set when creating the webhook in RZP dashboard

CRON_SECRET="generate-a-long-random-string"

# NextAuth (Auth.js v5) — generate with `npx auth secret`
AUTH_SECRET="generate-a-long-random-string"
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxxx"

# Cloudinary — signed admin uploads. Secret is server-only, never NEXT_PUBLIC_.
CLOUDINARY_CLOUD_NAME="xxxx"
CLOUDINARY_API_KEY="xxxx"
CLOUDINARY_API_SECRET="xxxx"

# Upstash Redis — rate limiting. Leave blank in local dev: routes fail OPEN (no limiting) if absent.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
