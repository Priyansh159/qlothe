// Qlothe — Phase 0 schema
// Money is ALWAYS integer paise. Never floats.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon POOLED string (-pooler host)
  directUrl = env("DIRECT_URL") // direct string — migrations use this
}

// ---------- enums ----------

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING // created, awaiting online payment
  COD_PENDING // cash-on-delivery, awaiting confirmation
  PAID
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  COD
}

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENT
  FLAT
}

// ---------- users ----------

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  phone        String?  @unique
  passwordHash String?  @map("password_hash") // null if OAuth-only
  name         String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now()) @map("created_at")

  addresses Address[]
  carts     Cart[]
  orders    Order[]
  reviews   Review[]
  accounts  Account[]
  sessions  Session[]

  @@map("users")
}

// ---------- NextAuth (Auth.js) — required by the Prisma adapter ----------
// Session strategy is JWT (Credentials provider forbids database sessions),
// so the Session table is unused at runtime but must exist for the adapter's
// type contract with the Prisma client.

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Address {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false) @map("is_default")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ---------- catalog ----------

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique // SEO URL: /products/{slug}
  name        String
  description String?
  category    String
  basePrice   Int      @map("base_price") // paise
  attributes  Json     @default("{}") // fabric, fit, design story…
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  images   ProductImage[]
  variants ProductVariant[]
  reviews  Review[]

  @@index([category, isActive])
  @@map("products")
}

model ProductImage {
  id                 String @id @default(uuid()) @db.Uuid
  productId          String @map("product_id") @db.Uuid
  cloudinaryPublicId String @map("cloudinary_public_id")
  sortOrder          Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  sku       String @unique // QLO-TEE-BULL-BLK-M
  size      String // S | M | L | XL | XXL
  color     String
  price     Int? // paise; null = inherit product.basePrice
  stock     Int    @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, size, color])
  @@index([productId])
  @@map("product_variants")
}

// ---------- cart ----------

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid // null = guest (cookie-keyed)
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items CartItem[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid()) @db.Uuid
  cartId    String @map("cart_id") @db.Uuid
  variantId String @map("variant_id") @db.Uuid
  quantity  Int

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ---------- orders ----------

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  orderNumber     String        @unique @map("order_number") // QLO-260703-A1B2
  userId          String        @map("user_id") @db.Uuid
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @map("payment_method")
  subtotal        Int // paise
  shippingFee     Int           @default(0) @map("shipping_fee")
  discount        Int           @default(0)
  total           Int
  gstAmount       Int           @default(0) @map("gst_amount")
  shippingAddress Json          @map("shipping_address") // SNAPSHOT, not FK
  couponCode      String?       @map("coupon_code")
  razorpayOrderId String?       @unique @map("razorpay_order_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  user          User                 @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  statusHistory OrderStatusHistory[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([status, createdAt]) // for the abandoned-order cron
  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid()) @db.Uuid
  orderId   String @map("order_id") @db.Uuid
  variantId String @map("variant_id") @db.Uuid

  // SNAPSHOTS at purchase time — the legal record. Never re-join products.
  productName  String @map("product_name")
  variantLabel String @map("variant_label") // "Black / M"
  sku          String
  unitPrice    Int    @map("unit_price") // paise, at time of purchase
  quantity     Int

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  orderId           String        @map("order_id") @db.Uuid
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id") // UNIQUE = webhook idempotency
  amount            Int // paise
  status            PaymentStatus
  rawWebhook        Json?         @map("raw_webhook") // keep the evidence
  createdAt         DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payments")
}

// ---------- marketing ----------

model Coupon {
  id        String     @id @default(uuid()) @db.Uuid
  code      String     @unique
  type      CouponType
  value     Int // PERCENT: 1-100 · FLAT: paise
  minOrder  Int        @default(0) @map("min_order")
  maxUses   Int?       @map("max_uses")
  usedCount Int        @default(0) @map("used_count")
  expiresAt DateTime?  @map("expires_at")
  isActive  Boolean    @default(true) @map("is_active")

  @@map("coupons")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int // 1-5, validated in Zod
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@map("reviews")
}
